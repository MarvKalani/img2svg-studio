{
  "name": "img2svg-studio-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -b && vite build",
    "benchmark:logo": "tsx benchmarks/logo-benchmark.ts",
    "benchmark:topography": "tsx benchmarks/topography-benchmark.ts",
    "capture:screenshots": "npm run build && playwright test --config=playwright.screenshots.config.ts",
    "dev": "vite --host 127.0.0.1",
    "preview": "vite preview",
    "test": "vitest run --passWithNoTests",
    "test:ai": "playwright test",
    "test:demo": "npm run build && playwright test --config=playwright.demo.config.ts",
    "test:e2e": "playwright test",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "@huggingface/transformers": "3.8.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@playwright/test": "1.61.1",
    "typescript": "7.0.2",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  }
}
